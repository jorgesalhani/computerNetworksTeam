@startuml

title Aceitar conexao de componente

control "Componente" as component
participant "Gerenciador" as manager
database "component_registry" as registry

component -> manager : HELLO
activate manager
note over component
  protocol_id: SMARTROOM/1.0
  message_type: HELLO
  source_id: identificador unico
  source_type: SENSOR | ACTUATOR | CLIENT
  payload.component_role: funcao do componente
end note

manager -> registry : validar source_id, source_type e component_role
activate registry

alt source_id nao cadastrado
  registry --> manager : nao encontrado
  deactivate registry
  manager --> component : ERROR
  note right of manager
    error_code: INVALID_COMPONENT
    details: source_id nao cadastrado
  end note

else source_type ou component_role incompativel
  registry --> manager : componente incompativel
  deactivate registry
  manager --> component : ERROR
  note right of manager
    error_code: INVALID_COMPONENT
    details: tipo ou papel incompativel
  end note

else componente aceito
  registry --> manager : componente valido
  deactivate registry
  manager --> component : ACK
  note right of manager
    status: registered
  end note
end

deactivate manager

@enduml
