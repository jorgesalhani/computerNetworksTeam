@startuml

title Desligar equipamentos apos ausencia prolongada

control "Sensor de presenca" as presence_sensor
participant "Gerenciador" as manager
control "ACT_LIGHT_01" as light
control "ACT_PROJECTOR_01" as projector
control "ACT_AC_01" as ac

presence_sensor -> manager : PRESENCE_UPDATE
activate manager
note over presence_sensor
  payload:
  {
    "presence_detected": false
  }
end note

manager -> manager : absence_started_at = now()
note right of manager
  No modo normal: 15 minutos.
  No modo demo: 15 segundos.
end note

alt now() - absence_started_at < 15min
  manager -> manager : manter estados atuais
else now() - absence_started_at >= 15min
  manager -> light : ACTUATOR_COMMAND
  activate light
  note right of light
    payload:
    {
      "actuator_id": "ACT_LIGHT_01",
      "command": "OFF",
      "reason": "absence_timeout"
    }
  end note
  light --> manager : ACK
  deactivate light

  manager -> projector : ACTUATOR_COMMAND
  activate projector
  note right of projector
    payload:
    {
      "actuator_id": "ACT_PROJECTOR_01",
      "command": "OFF",
      "reason": "absence_timeout"
    }
  end note
  projector --> manager : ACK
  deactivate projector

  manager -> ac : ACTUATOR_COMMAND
  activate ac
  note right of ac
    payload:
    {
      "actuator_id": "ACT_AC_01",
      "command": "OFF",
      "reason": "absence_timeout"
    }
  end note
  ac --> manager : ACK
  deactivate ac
end

deactivate manager

@enduml
