@startuml

title Registrar presenca de aluno

control "Leitor de cartao" as card_reader
participant "Gerenciador" as manager
database "lista_presenca" as attendance_list

card_reader -> manager : STUDENT_CHECKIN
activate manager
note over card_reader
  payload:
  {
    "student_number": "001",
    "student_name": "Aluno 1"
  }
end note

manager -> attendance_list : buscar por student_number
activate attendance_list

alt student_number ja registrado
  attendance_list --> manager : aluno existente
  manager -> manager : nao duplicar registro
else novo student_number
  attendance_list --> manager : nao encontrado
  manager -> attendance_list : salvar student_number, student_name, checkin_timestamp
  attendance_list --> manager : registro salvo
end

deactivate attendance_list
deactivate manager

@enduml
